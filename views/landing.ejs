<!DOCTYPE html>
<html lang="en">
<head>
    <title>LoveMemory</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background-color: #f8f9fa;">
    <nav class="navbar navbar-dark d-flex justify-content-center py-3 shadow-sm navbar-love">
        <div class="d-flex align-items-center gap-2">
            <div class="navbar-brand text-white fw-bold fs-3"> Welcome to Love Memories 💝</div>
            <img src="/images/bubududu.jpg" alt="LoveMemory logo" height="60">
        </div>
    </nav>

    <div class="container d-flex justify-content-center mt-5">
        <div class="card rounded-4 shadow-lg" style="width: 75%;">
            <div class="card-body p-4 text-center">
                <div class="mb-4">
                    <h5 class="card-title fw-normal">Not a member?</h5>
                    <a href="/register" class="btn btn-outline-danger rounded-pill btn-lg fw-bold">Sign up here 📱</a>
                </div>

                <hr>

                <div class="mt-4">
                    <h5 class="card-title fw-normal">Already a member?</h5>
                    <a href="/login" class="btn btn-outline-danger btn-lg rounded-pill fw-bold">Login here 🥰</a>
                </div>
            </div>
        </div>
    </div>
</body>
<footer class="text-center text-muted mt-5 mb-3">
    <p> Made with 💝 by me - Love Memories © 2026 </p>
</footer>
</html>
