<!DOCTYPE html>
<html lang="en">
<head>
    <title>LoveMemory</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background-color: #f8f9fa;">
    <nav class="navbar navbar-dark d-flex justify-content-center py-3 shadow-sm navbar-love">
        <div class="d-flex align-items-center gap-2">
            <div class="navbar-brand text-white fw-bold fs-3"> Welcome to Love Memories 💝</div>
            <img src="/images/bubududu.jpg" alt="LoveMemory logo" height="60">
        </div>
    </nav>
    <div class="container d-flex justify-content-center mt-5">
        <div class="card rounded-4 shadow-lg" style="width: 75%">
            <div class="card-body p-4 text-center">
                <h3 class="fw-bold mb-4" style="color: #c2185b;">Login</h3>
                <form action="/login" method="post">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" name="username" id="username" placeholder="username">
                        <label for="username"> Username</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" name="password" id="password" placeholder="Password">
                        <label for="password">Password</label>
                    </div>

                    <button class="btn btn-outline-danger rounded-pill btn-lg fw-bold"> Login</button>
                    
                </form>

                <% if (error) { %>
                    <p class="text-danger fw-bold"><%= error %></p>
                <% } %>
            </div>
        </div>
    </div>

<footer class="text-center text-muted mt-5 mb-3">
    <p> Made with 💝 by me - Love Memories © 2026 </p>
</footer>

</body>

</html>
